# This project must start in paper-trading mode only.
KALSHI_ENABLE_REAL_ORDERS=false
KALSHI_API_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_DEMO_API_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2
DEFAULT_SERIES=KXHIGHLAX

# Not needed for public read-only market data. Keep empty during first build.
KALSHI_ACCESS_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Weather APIs. NWS requires a descriptive User-Agent.
DEFAULT_STATION=KLAX
NWS_API_BASE_URL=https://api.weather.gov
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/gfs
NWS_USER_AGENT=kalshi-weather-research/0.1 your_email@example.com

# Model
RESIDUAL_SIGMA_F=1.0
MONTE_CARLO_SAMPLES=20000

# Paper trading
PAPER_STARTING_CASH=1000.00
PAPER_MAX_POSITION_PER_MARKET=25
PAPER_MAX_ORDER_COST=25.00
PAPER_DEFAULT_QUANTITY=1
MIN_EDGE=0.05
FEE_BUFFER=0.01
MODEL_ERROR_BUFFER=0.03
PROFIT_TARGET=0.08
STOP_LOSS=0.08
MAX_HOLD_MINUTES=180
POLLING_INTERVAL_SECONDS=60

# Runtime
LOG_LEVEL=INFO
SQLITE_PATH=data/kalshi_weather.sqlite
SNAPSHOT_DIR=data/snapshots
